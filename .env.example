# ========================================
# AI Cowork — Example Configuration
# ========================================
# Copy this file to .env and adjust values

# LLM Provider: ollama | openai | anthropic
LLM_PROVIDER=ollama

# Ollama (local, runs in Docker)
OLLAMA_URL=http://localhost:11434
REASONING_MODEL=qwen2.5:7b

# OpenAI (optional — set provider to "openai")
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude (optional — set provider to "anthropic")
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Screen capture
CAPTURE_INTERVAL=5
HISTORY_SIZE=50

# Privacy — comma-separated window titles to exclude from capture
# PRIVACY_EXCLUDE=banking,1password,keepass

# Dashboard
DASHBOARD_PORT=8080

# Tesseract (Windows default — change if installed elsewhere)
# TESSERACT_PATH=C:\Users\YOU\AppData\Local\Programs\Tesseract-OCR\tesseract.exe
